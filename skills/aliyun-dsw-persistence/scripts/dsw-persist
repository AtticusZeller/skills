#!/usr/bin/env bash
set -Eeuo pipefail

readonly OSS_URI="oss://qiongming.oss-cn-beijing-internal.aliyuncs.com/lingjing/"
readonly DEFAULT_MOUNT_PATH="/mnt/data"
readonly PERSONAL_DIR_NAME="atticux"
readonly MANAGED_START="# >>> aliyun-dsw-persistence >>>"
readonly MANAGED_END="# <<< aliyun-dsw-persistence <<<"
readonly CODEX_AGENTS_START="<!-- >>> aliyun-dsw-persistence >>> -->"
readonly CODEX_AGENTS_END="<!-- <<< aliyun-dsw-persistence <<< -->"

resolve_script_path() {
    local source="${BASH_SOURCE[0]}"
    local directory target

    while [[ -L "$source" ]]; do
        directory="$(cd -P -- "$(dirname -- "$source")" && pwd)"
        target="$(readlink -- "$source")"
        if [[ "$target" == /* ]]; then
            source="$target"
        else
            source="$directory/$target"
        fi
    done

    directory="$(cd -P -- "$(dirname -- "$source")" && pwd)"
    printf '%s/%s\n' "$directory" "$(basename -- "$source")"
}

readonly SCRIPT_PATH="$(resolve_script_path)"
readonly SCRIPT_DIR="${SCRIPT_PATH%/*}"
readonly ENV_TEMPLATE="$SCRIPT_DIR/../assets/env.sh.template"
readonly CODEX_AGENTS_BLOCK="$SCRIPT_DIR/../assets/codex-agents-block.md"

if [[ "${DSW_PERSIST_TESTING:-0}" == "1" && -n "${DSW_PERSIST_TEST_MOUNT_PATH:-}" ]]; then
    MOUNT_PATH="${DSW_PERSIST_TEST_MOUNT_PATH%/}"
else
    MOUNT_PATH="$DEFAULT_MOUNT_PATH"
fi

readonly MOUNT_PATH
readonly PERSIST_ROOT="$MOUNT_PATH/$PERSONAL_DIR_NAME"
readonly CONFIG_DIR="${HOME:?HOME is not set}/.config/dsw-persistence"
readonly ENV_FILE="$CONFIG_DIR/env.sh"
readonly INSTALL_PATH="$HOME/.local/bin/dsw-persist"
readonly CODEX_HOME_DIR="${CODEX_HOME:-$HOME/.codex}"
readonly CODEX_AGENTS_FILE="$CODEX_HOME_DIR/AGENTS.md"

log() {
    printf '%s\n' "$*"
}

warn() {
    printf 'WARN: %s\n' "$*" >&2
}

die() {
    printf 'ERROR: %s\n' "$*" >&2
    exit 1
}

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

same_path() {
    [[ "${1%/}" == "${2%/}" ]]
}

is_confirmed_mountpoint() {
    [[ -d "$MOUNT_PATH" ]] || return 1

    if command_exists mountpoint; then
        mountpoint -q -- "$MOUNT_PATH"
        return
    fi

    if command_exists findmnt; then
        local target
        target="$(findmnt -n -T "$MOUNT_PATH" -o TARGET 2>/dev/null || true)"
        [[ -n "$target" ]] && same_path "$target" "$MOUNT_PATH"
        return
    fi

    if [[ -r /proc/self/mountinfo ]]; then
        awk -v expected="$MOUNT_PATH" '$5 == expected { found = 1 } END { exit !found }' \
            /proc/self/mountinfo
        return
    fi

    return 1
}

print_unconfirmed_mount_message() {
    cat >&2 <<EOF
$MOUNT_PATH 当前不是已确认的持久化挂载点。

不要在这里下载大模型或写入重要数据，否则文件可能实际进入 DSW 实例系统盘，并在实例删除后丢失。

请在创建 DSW 实例时确认：
OSS URI: $OSS_URI
Mount Path: /mnt/data/
EOF
}

show_mount_details() {
    log "挂载信息："
    if command_exists findmnt; then
        findmnt -T "$MOUNT_PATH" -o TARGET,SOURCE,FSTYPE,OPTIONS || true
    elif [[ -r /proc/mounts ]]; then
        awk -v expected="$MOUNT_PATH" '
            $2 == expected {
                printf "TARGET=%s SOURCE=%s FSTYPE=%s OPTIONS=%s\n", $2, $1, $3, $4
            }
        ' /proc/mounts
    else
        warn "缺少 findmnt，且无法读取 /proc/mounts。"
    fi

    log "容量信息："
    if command_exists df; then
        df -hT "$MOUNT_PATH" || true
    else
        warn "缺少 df，无法显示容量。"
    fi
}

test_mount_writable() {
    local probe
    probe="$(mktemp "$MOUNT_PATH/.dsw-persist-write-test.XXXXXX" 2>/dev/null)" || return 1
    rm -f -- "$probe" || return 1
}

expected_env_value() {
    case "$1" in
        DSW_PERSIST_ROOT) printf '%s\n' "$PERSIST_ROOT" ;;
        HF_HOME) printf '%s\n' "$PERSIST_ROOT/cache/huggingface" ;;
        HF_HUB_CACHE) printf '%s\n' "$PERSIST_ROOT/cache/huggingface/hub" ;;
        HF_DATASETS_CACHE) printf '%s\n' "$PERSIST_ROOT/cache/huggingface/datasets" ;;
        MODELSCOPE_CACHE) printf '%s\n' "$PERSIST_ROOT/cache/modelscope" ;;
        TORCH_HOME) printf '%s\n' "$PERSIST_ROOT/cache/torch" ;;
        PIP_CACHE_DIR) printf '%s\n' "$PERSIST_ROOT/cache/pip" ;;
        UV_CACHE_DIR) printf '%s\n' "$PERSIST_ROOT/cache/uv" ;;
        *) return 1 ;;
    esac
}

check_environment() {
    local name value expected missing=0
    local -a names=(
        DSW_PERSIST_ROOT
        HF_HOME
        HF_HUB_CACHE
        HF_DATASETS_CACHE
        MODELSCOPE_CACHE
        TORCH_HOME
        PIP_CACHE_DIR
        UV_CACHE_DIR
    )

    log "环境变量："
    for name in "${names[@]}"; do
        value="${!name-}"
        expected="$(expected_env_value "$name")"
        if [[ "$value" == "$expected" ]]; then
            printf '  OK   %s=%s\n' "$name" "$value"
        elif [[ -n "$value" ]]; then
            printf '  WARN %s=%s（预期 %s）\n' "$name" "$value" "$expected"
            missing=1
        else
            printf '  WARN %s 未配置（预期 %s）\n' "$name" "$expected"
            missing=1
        fi
    done

    if ((missing != 0)); then
        warn "运行 dsw-persist init 后重新加载 shell 配置。"
    fi
}

check_command_path() {
    local resolved
    resolved="$(command -v dsw-persist 2>/dev/null || true)"
    if [[ -n "$resolved" ]]; then
        log "PATH：OK（$resolved）"
    else
        warn "PATH 中找不到 dsw-persist；运行 scripts/dsw-persist install-command。"
    fi
}

doctor() {
    local rc=0

    log "DSW 持久化环境检查"
    log "目标挂载：$MOUNT_PATH"

    if [[ ! -e "$MOUNT_PATH" ]]; then
        warn "$MOUNT_PATH 不存在。"
        print_unconfirmed_mount_message
        return 1
    fi

    if [[ ! -d "$MOUNT_PATH" ]]; then
        warn "$MOUNT_PATH 不是目录。"
        print_unconfirmed_mount_message
        return 1
    fi

    if ! is_confirmed_mountpoint; then
        show_mount_details
        print_unconfirmed_mount_message
        return 1
    fi

    log "挂载点：OK（已确认是独立挂载点）"
    show_mount_details
    log "注意：本地命令不能可靠验证完整 OSS URI，请与 DSW 控制台配置人工核对。"

    if [[ -r "$MOUNT_PATH" ]]; then
        log "可读性：OK"
    else
        warn "$MOUNT_PATH 不可读。"
        rc=1
    fi

    if test_mount_writable; then
        log "可写性：OK"
    else
        warn "$MOUNT_PATH 不可写；不会执行初始化。"
        rc=1
    fi

    if [[ -d "$PERSIST_ROOT" ]]; then
        log "个人目录：OK（$PERSIST_ROOT）"
    elif [[ -e "$PERSIST_ROOT" ]]; then
        warn "$PERSIST_ROOT 已存在但不是目录。"
        rc=1
    else
        warn "$PERSIST_ROOT 尚未初始化。"
    fi

    check_environment
    check_command_path
    return "$rc"
}

require_ready_mount() {
    [[ -d "$MOUNT_PATH" ]] || {
        print_unconfirmed_mount_message
        return 1
    }

    is_confirmed_mountpoint || {
        print_unconfirmed_mount_message
        return 1
    }

    [[ -r "$MOUNT_PATH" ]] || {
        warn "$MOUNT_PATH 不可读，拒绝初始化。"
        return 1
    }

    test_mount_writable || {
        warn "$MOUNT_PATH 不可写，拒绝初始化。请在 DSW 控制台确认 OSS 挂载具有读写权限。"
        return 1
    }
}

print_env_exports() {
    cat <<EOF
export DSW_MOUNT_PATH="$MOUNT_PATH"
export DSW_PERSIST_ROOT="$PERSIST_ROOT"

export DSW_MODELS_DIR="\$DSW_PERSIST_ROOT/models"
export DSW_DATASETS_DIR="\$DSW_PERSIST_ROOT/datasets"
export DSW_CHECKPOINTS_DIR="\$DSW_PERSIST_ROOT/checkpoints"
export DSW_OUTPUTS_DIR="\$DSW_PERSIST_ROOT/outputs"
export DSW_ARCHIVES_DIR="\$DSW_PERSIST_ROOT/archives"

export HF_HOME="\$DSW_PERSIST_ROOT/cache/huggingface"
export HF_HUB_CACHE="\$HF_HOME/hub"
export HF_DATASETS_CACHE="\$HF_HOME/datasets"

export MODELSCOPE_CACHE="\$DSW_PERSIST_ROOT/cache/modelscope"
export TORCH_HOME="\$DSW_PERSIST_ROOT/cache/torch"

export PIP_CACHE_DIR="\$DSW_PERSIST_ROOT/cache/pip"
export UV_CACHE_DIR="\$DSW_PERSIST_ROOT/cache/uv"
EOF
}

render_env_file() {
    local line=""

    [[ -f "$ENV_TEMPLATE" ]] || die "缺少环境配置模板：$ENV_TEMPLATE"
    shopt -u patsub_replacement 2>/dev/null || true

    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line//\{\{MOUNT_PATH\}\}/$MOUNT_PATH}"
        line="${line//\{\{PERSIST_ROOT\}\}/$PERSIST_ROOT}"
        printf '%s\n' "$line"
    done <"$ENV_TEMPLATE"
}

backup_file() {
    local file="$1"
    local backup
    backup="${file}.bak.$(date '+%Y%m%d%H%M%S').$$"
    cp -p -- "$file" "$backup"
    log "已备份：$backup"
}

write_env_file() {
    local tmp
    mkdir -p -- "$CONFIG_DIR"
    tmp="$(mktemp "$CONFIG_DIR/.env.sh.tmp.XXXXXX")"
    render_env_file >"$tmp"
    chmod 0644 "$tmp"

    if [[ -f "$ENV_FILE" ]] && cmp -s -- "$tmp" "$ENV_FILE"; then
        rm -f -- "$tmp"
        log "环境配置未变化：$ENV_FILE"
        return
    fi

    if [[ -e "$ENV_FILE" ]]; then
        [[ -f "$ENV_FILE" ]] || die "$ENV_FILE 已存在但不是普通文件。"
        backup_file "$ENV_FILE"
    fi

    mv -- "$tmp" "$ENV_FILE"
    log "已写入：$ENV_FILE"
}

managed_block() {
    cat <<'EOF'
# >>> aliyun-dsw-persistence >>>
if [ -f "$HOME/.config/dsw-persistence/env.sh" ]; then
    . "$HOME/.config/dsw-persistence/env.sh"
fi
# <<< aliyun-dsw-persistence <<<
EOF
}

ensure_shell_block() {
    local file="$1"
    local start_count end_count

    if [[ -e "$file" && ! -f "$file" ]]; then
        die "$file 已存在但不是普通文件。"
    fi

    if [[ ! -e "$file" ]]; then
        managed_block >"$file"
        log "已创建并配置：$file"
        return
    fi

    start_count="$(grep -Fxc "$MANAGED_START" "$file" || true)"
    end_count="$(grep -Fxc "$MANAGED_END" "$file" || true)"

    if [[ "$start_count" == "1" && "$end_count" == "1" ]]; then
        log "shell 配置已存在：$file"
        return
    fi

    if [[ "$start_count" != "0" || "$end_count" != "0" ]]; then
        die "$file 中的 aliyun-dsw-persistence managed block 不完整或重复，请人工检查。"
    fi

    backup_file "$file"
    printf '\n%s\n' "$(managed_block)" >>"$file"
    log "已配置：$file"
}

codex_agents_block_is_current() {
    [[ -f "$CODEX_AGENTS_FILE" && -f "$CODEX_AGENTS_BLOCK" ]] || return 1
    awk -v start="$CODEX_AGENTS_START" -v end="$CODEX_AGENTS_END" '
        $0 == start { capture = 1 }
        capture { print }
        capture && $0 == end { exit }
    ' "$CODEX_AGENTS_FILE" | cmp -s - "$CODEX_AGENTS_BLOCK"
}

ensure_codex_agents_block() {
    local start_count end_count tmp line skipping=0

    [[ -f "$CODEX_AGENTS_BLOCK" ]] || die "缺少 Codex AGENTS 模板：$CODEX_AGENTS_BLOCK"
    [[ "$(grep -Fxc "$CODEX_AGENTS_START" "$CODEX_AGENTS_BLOCK" || true)" == "1" ]] ||
        die "Codex AGENTS 模板缺少唯一的开始标记。"
    [[ "$(grep -Fxc "$CODEX_AGENTS_END" "$CODEX_AGENTS_BLOCK" || true)" == "1" ]] ||
        die "Codex AGENTS 模板缺少唯一的结束标记。"

    mkdir -p -- "$CODEX_HOME_DIR"
    if [[ ! -e "$CODEX_AGENTS_FILE" ]]; then
        install -m 0644 "$CODEX_AGENTS_BLOCK" "$CODEX_AGENTS_FILE"
        log "已创建并配置：$CODEX_AGENTS_FILE"
        return
    fi
    [[ -f "$CODEX_AGENTS_FILE" ]] || die "$CODEX_AGENTS_FILE 已存在但不是普通文件。"

    start_count="$(grep -Fxc "$CODEX_AGENTS_START" "$CODEX_AGENTS_FILE" || true)"
    end_count="$(grep -Fxc "$CODEX_AGENTS_END" "$CODEX_AGENTS_FILE" || true)"

    if [[ "$start_count" == "0" && "$end_count" == "0" ]]; then
        backup_file "$CODEX_AGENTS_FILE"
        printf '\n' >>"$CODEX_AGENTS_FILE"
        cat "$CODEX_AGENTS_BLOCK" >>"$CODEX_AGENTS_FILE"
        log "已配置：$CODEX_AGENTS_FILE"
        return
    fi

    if [[ "$start_count" != "1" || "$end_count" != "1" ]]; then
        die "$CODEX_AGENTS_FILE 中的 aliyun-dsw-persistence managed block 不完整或重复，请人工检查。"
    fi

    if codex_agents_block_is_current; then
        log "Codex 全局规则已存在：$CODEX_AGENTS_FILE"
        return
    fi

    backup_file "$CODEX_AGENTS_FILE"
    tmp="$(mktemp "$CODEX_HOME_DIR/.AGENTS.md.tmp.XXXXXX")"
    while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ "$line" == "$CODEX_AGENTS_START" ]]; then
            cat "$CODEX_AGENTS_BLOCK" >>"$tmp"
            skipping=1
            continue
        fi
        if ((skipping != 0)); then
            if [[ "$line" == "$CODEX_AGENTS_END" ]]; then
                skipping=0
            fi
            continue
        fi
        printf '%s\n' "$line" >>"$tmp"
    done <"$CODEX_AGENTS_FILE"
    chmod --reference="$CODEX_AGENTS_FILE" "$tmp"
    mv -- "$tmp" "$CODEX_AGENTS_FILE"
    log "已更新：$CODEX_AGENTS_FILE"
}

codex_agents_status() {
    if codex_agents_block_is_current; then
        printf '  OK   %s\n' "$CODEX_AGENTS_FILE"
    else
        printf '  WARN %s 未配置或内容过期\n' "$CODEX_AGENTS_FILE"
    fi
}

install_command() {
    local current_target backup

    [[ -f "$ENV_TEMPLATE" ]] || die "缺少环境配置模板：$ENV_TEMPLATE"
    [[ -f "$CODEX_AGENTS_BLOCK" ]] || die "缺少 Codex AGENTS 模板：$CODEX_AGENTS_BLOCK"
    mkdir -p -- "${INSTALL_PATH%/*}"

    if [[ -L "$INSTALL_PATH" ]]; then
        current_target="$(readlink -f -- "$INSTALL_PATH" 2>/dev/null || true)"
        if [[ "$current_target" == "$SCRIPT_PATH" ]]; then
            log "命令已安装：$INSTALL_PATH -> $SCRIPT_PATH"
            return
        fi
    fi

    if [[ -e "$INSTALL_PATH" || -L "$INSTALL_PATH" ]]; then
        [[ -f "$INSTALL_PATH" || -L "$INSTALL_PATH" ]] ||
            die "$INSTALL_PATH 已存在但不是普通文件或符号链接。"
        backup="${INSTALL_PATH}.bak.$(date '+%Y%m%d%H%M%S').$$"
        mv -- "$INSTALL_PATH" "$backup"
        log "已备份原命令：$backup"
    fi

    ln -s -- "$SCRIPT_PATH" "$INSTALL_PATH"
    log "已安装：$INSTALL_PATH -> $SCRIPT_PATH"
}

init_persistence() {
    local -a directories=(
        "$PERSIST_ROOT/models"
        "$PERSIST_ROOT/datasets"
        "$PERSIST_ROOT/checkpoints"
        "$PERSIST_ROOT/outputs"
        "$PERSIST_ROOT/archives"
        "$PERSIST_ROOT/cache/huggingface"
        "$PERSIST_ROOT/cache/modelscope"
        "$PERSIST_ROOT/cache/torch"
        "$PERSIST_ROOT/cache/pip"
        "$PERSIST_ROOT/cache/uv"
        "$PERSIST_ROOT/cache/downloads"
    )

    require_ready_mount || return 1
    [[ -f "$ENV_TEMPLATE" ]] || die "缺少环境配置模板：$ENV_TEMPLATE"
    [[ -f "$CODEX_AGENTS_BLOCK" ]] || die "缺少 Codex AGENTS 模板：$CODEX_AGENTS_BLOCK"
    mkdir -p -- "${directories[@]}"
    log "持久化目录已就绪：$PERSIST_ROOT"

    write_env_file
    ensure_shell_block "$HOME/.bashrc"
    if [[ -e "$HOME/.zshrc" ]]; then
        ensure_shell_block "$HOME/.zshrc"
    fi
    ensure_codex_agents_block

    log "初始化完成。重新加载 shell：source ~/.bashrc"
}

shell_block_status() {
    local file="$1"
    if [[ -f "$file" ]] &&
        grep -Fqx "$MANAGED_START" "$file" &&
        grep -Fqx "$MANAGED_END" "$file"; then
        printf '  OK   %s\n' "$file"
    else
        printf '  WARN %s 未配置\n' "$file"
    fi
}

status() {
    local rc=0 dir
    local -a relative_dirs=(
        models
        datasets
        checkpoints
        outputs
        archives
        cache/huggingface
        cache/modelscope
        cache/torch
        cache/pip
        cache/uv
        cache/downloads
    )

    doctor || rc=$?

    log "目录状态："
    for dir in "${relative_dirs[@]}"; do
        if [[ -d "$PERSIST_ROOT/$dir" ]]; then
            printf '  OK   %s\n' "$PERSIST_ROOT/$dir"
        else
            printf '  WARN %s 不存在\n' "$PERSIST_ROOT/$dir"
        fi
    done

    log "配置文件："
    if [[ -f "$ENV_FILE" ]]; then
        printf '  OK   %s\n' "$ENV_FILE"
    else
        printf '  WARN %s 不存在\n' "$ENV_FILE"
    fi
    shell_block_status "$HOME/.bashrc"
    if [[ -e "$HOME/.zshrc" ]]; then
        shell_block_status "$HOME/.zshrc"
    fi
    codex_agents_status

    return "$rc"
}

help_text() {
    cat <<'EOF'
用法：dsw-persist <command>

命令：
  doctor          检查 /mnt/data 的挂载、读写权限、环境变量和 PATH
  init            初始化持久化目录、shell 配置与 Codex 全局规则
  status          显示挂载、目录和配置状态
  print-env       输出建议的环境变量配置
  install-command 将本脚本链接到 $HOME/.local/bin/dsw-persist
  help            显示此帮助

重要约定：
  - 代码放在 $HOME/<project>，虚拟环境放在 $HOME/<project>/.venv。
  - 模型、数据集、checkpoint、输出和下载缓存放在 /mnt/data/atticux。
  - 下载大文件或开始训练前先运行 dsw-persist doctor。
  - 本命令不验证完整 OSS URI，请与 DSW 控制台配置人工核对。
EOF
}

main() {
    case "${1:-help}" in
        doctor) doctor ;;
        init) init_persistence ;;
        status) status ;;
        print-env) print_env_exports ;;
        install-command) install_command ;;
        help | -h | --help) help_text ;;
        *)
            help_text >&2
            die "未知命令：$1"
            ;;
    esac
}

main "$@"
