# Managed by aliyun-dsw-persistence. Safe to source from bash and zsh.

case ":${PATH:-}:" in
    *":$HOME/.local/bin:"*) ;;
    *) export PATH="$HOME/.local/bin${PATH:+:$PATH}" ;;
esac

export DSW_MOUNT_PATH="{{MOUNT_PATH}}"

_dsw_persistence_mounted=0
if [ -d "$DSW_MOUNT_PATH" ]; then
    if command -v mountpoint >/dev/null 2>&1; then
        if mountpoint -q -- "$DSW_MOUNT_PATH"; then
            _dsw_persistence_mounted=1
        fi
    elif command -v findmnt >/dev/null 2>&1; then
        _dsw_persistence_target=$(findmnt -n -T "$DSW_MOUNT_PATH" -o TARGET 2>/dev/null || true)
        if [ "${_dsw_persistence_target%/}" = "${DSW_MOUNT_PATH%/}" ]; then
            _dsw_persistence_mounted=1
        fi
        unset _dsw_persistence_target
    elif [ -r /proc/self/mountinfo ]; then
        if awk -v expected="$DSW_MOUNT_PATH" '$5 == expected { found = 1 } END { exit !found }' /proc/self/mountinfo; then
            _dsw_persistence_mounted=1
        fi
    fi
fi

if [ "$_dsw_persistence_mounted" -ne 1 ]; then
    case "$-" in
        *i*) printf '%s\n' "警告：/mnt/data 未确认为持久化挂载点，DSW 缓存环境变量未加载。" >&2 ;;
    esac
    unset _dsw_persistence_mounted DSW_MOUNT_PATH
    return 0 2>/dev/null || exit 0
fi
unset _dsw_persistence_mounted

export DSW_PERSIST_ROOT="{{PERSIST_ROOT}}"

export DSW_MODELS_DIR="$DSW_PERSIST_ROOT/models"
export DSW_DATASETS_DIR="$DSW_PERSIST_ROOT/datasets"
export DSW_CHECKPOINTS_DIR="$DSW_PERSIST_ROOT/checkpoints"
export DSW_OUTPUTS_DIR="$DSW_PERSIST_ROOT/outputs"
export DSW_ARCHIVES_DIR="$DSW_PERSIST_ROOT/archives"

export HF_HOME="$DSW_PERSIST_ROOT/cache/huggingface"
export HF_HUB_CACHE="$HF_HOME/hub"
export HF_DATASETS_CACHE="$HF_HOME/datasets"

export MODELSCOPE_CACHE="$DSW_PERSIST_ROOT/cache/modelscope"
export TORCH_HOME="$DSW_PERSIST_ROOT/cache/torch"

export PIP_CACHE_DIR="$DSW_PERSIST_ROOT/cache/pip"
export UV_CACHE_DIR="$DSW_PERSIST_ROOT/cache/uv"
